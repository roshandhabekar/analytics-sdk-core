{
  "name": "analytics-sdk-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Core TypeScript SDK for centralized analytics CDN integration (framework-agnostic)",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "analytics",
    "sdk",
    "google-analytics",
    "clevertap",
    "module-federation",
    "microfrontend",
    "cdn",
    "tracking"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/analytics-sdk.git",
    "directory": "packages/analytics-sdk-core"
  },
  "homepage": "https://github.com/your-org/analytics-sdk/tree/main/packages/analytics-sdk-core#readme",
  "bugs": {
    "url": "https://github.com/your-org/analytics-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {},
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^11.1.2",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.5",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "rollup": "^3.27.2",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.1",
    "typescript": "^5.0.0"
  }
}
